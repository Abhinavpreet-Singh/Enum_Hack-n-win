generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

type UserLinks {
  github  String @default("")
  linkedin String @default("")
  website String @default("")
}

type UserCert {
  name   String
  issuer String
  date   String
  done   Boolean @default(false)
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  username     String   @unique
  email        String   @unique
  password     String
  refreshToken String?
  displayName  String?
  bio          String   @default("")
  college      String   @default("")
  role         String   @default("Student")
  location     String   @default("")
  resume       String   @default("")
  skills       String[] @default([])
  links        UserLinks?
  certs        UserCert[]
  avatar       String   @default("")

  solutions              Solution[]
  submissions            Submission[]
  simulationProgress     UserSimulationProgress[]
  simulationSubmissions  SimulationSubmission[]

  @@map("users")
}

// ─── Question ────────────────────────────────────────────────────────────────

model Question {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String?
  desc           String?
  level          String   @default("Easy") // "Easy" | "Medium" | "Hard"
  testcases      Json[]
  constraints    String?
  topic          String?
  functionName   String
  parameterNames String[] @default([])
  parameterTypes String[]
  returnType     String
  initialCode    Json[]   @default([])

  solutions      Solution[]
  submissions    Submission[]
  editorials     Editorial[]

  @@map("questions")
}

// ─── Solution ────────────────────────────────────────────────────────────────

model Solution {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId String   @db.ObjectId
  userId     String   @db.ObjectId
  code       String
  language   String   @default("javascript")
  upvotes    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("solutions")
}

// ─── Submission ──────────────────────────────────────────────────────────────

model Submission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId  String   @db.ObjectId
  userId      String   @db.ObjectId
  code        String
  language    String   @default("python")
  verdict     String   @default("wrong_answer") // accepted | wrong_answer | runtime_error | compile_error | error | partial
  passedCount Int      @default(0)
  totalCount  Int      @default(0)
  runtime     Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("submissions")
}

// ─── Editorial ───────────────────────────────────────────────────────────────

model Editorial {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId      String   @unique @db.ObjectId
  title           String
  intuition       String?
  approach        String?
  algorithm       String?
  code            String?
  timeComplexity  String?
  spaceComplexity String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id])

  @@map("editorials")
}

// ─── Simulation ──────────────────────────────────────────────────────────────

type SimulationFile {
  name              String @default("")
  path              String @default("")
  content           String @default("")
  language          String @default("javascript")
  cloudinaryUrl     String @default("")
  cloudinaryPublicId String @default("")
}

type SimulationStep {
  description String @default("")
}

model Simulation {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  category       String           // "frontend" | "backend" | "fullstack" | "devops"
  difficulty     String           @default("easy") // "easy" | "medium" | "hard"
  description    String
  incident       String
  steps          SimulationStep[]
  initialFiles   SimulationFile[]
  solution       Json             @default("{}")
  hints          String[]         @default([])
  estimatedTime  Int              @default(15)
  tags           String[]         @default([])
  xpReward       Int              @default(50)
  entryFile      String           @default("index.js")
  expectedOutput String           @default("")
  testCommands   String[]         @default([])
  testPort       Int              @default(3000)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  progress              UserSimulationProgress[]
  simulationSubmissions SimulationSubmission[]

  @@map("simulations")
}

// ─── UserSimulationProgress ──────────────────────────────────────────────────

model UserSimulationProgress {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  simulationId  String    @db.ObjectId
  solved        Boolean   @default(false)
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  modifiedFiles Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  simulation Simulation @relation(fields: [simulationId], references: [id])

  @@unique([userId, simulationId])
  @@map("usersimulationprogresses")
}

// ─── SimulationSubmission ────────────────────────────────────────────────────

model SimulationSubmission {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  simulationId  String   @db.ObjectId
  editedFiles   Json[]
  score         Float    @default(0)
  logs          String   @default("")
  passedTests   Int      @default(0)
  totalTests    Int      @default(0)
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  simulation Simulation @relation(fields: [simulationId], references: [id])

  @@map("simulationsubmissions")
}
